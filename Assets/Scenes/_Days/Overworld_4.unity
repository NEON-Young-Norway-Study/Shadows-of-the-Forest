      propertyPath: 'dialogueLines.Array.data[0]'
      value: I made one to show support
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "I wanted to leave you be. I didn\u2019t know how to help"
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
