--- !u!1001 &515219453
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1462565334}
    m_Modifications:
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 4
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "\"Just know that losin\u2019 someone ain't easy\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "\"It\u2019ll knock the wind right outta ya, even us cold-blooded folks
        sometimes shed a tear\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: "\"But that ain\u2019t no reason to go hungry. You\u2019re not alone
        out here, y\u2019hear?\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: "\"If you ever need a hand, I\u2019m right here\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[4]'
      value: (you got the thing)
      objectReference: {fileID: 0}
