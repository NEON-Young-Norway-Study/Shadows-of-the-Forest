      objectReference: {fileID: 21300000, guid: 802ec4e72bc24f145bcbecb4fe331aa2, type: 3}
    - target: {fileID: 6471687835304885810, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: '"Quiet one, huh?"'
      objectReference: {fileID: 0}
    - target: {fileID: 6471687835304885810, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: '"Smart not to talk too much to strangers... even friendly ones"'
      objectReference: {fileID: 0}
    - target: {fileID: 6722014778278293823, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: m_text
      value: Who did you lose?
      objectReference: {fileID: 0}
