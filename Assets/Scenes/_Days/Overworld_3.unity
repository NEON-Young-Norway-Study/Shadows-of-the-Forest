      propertyPath: 'dialogueLines.Array.data[0]'
      value: '"Did you lose someone?"'
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "But listen, I\u2019m really sorry for your loss, kid. Your dad was
