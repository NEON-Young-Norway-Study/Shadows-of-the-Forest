--- !u!1001 &1451160264
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1462565334}
    m_Modifications:
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "\"Heh, moved out here myself. Got tired of the dry lands, salmon\u2019s
        better eatin\u2019 \""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "\"But listen, I\u2019m really sorry for your loss, kid. Your dad was
        a good man\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: "\"Life ain\u2019t easy when you lose someone you love\""
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: So take the activation.key_school and continue the game
      objectReference: {fileID: 0}
    - target: {fileID: 4654630718448193217, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: 'dialogueLines.Array.data[4]'
      value: (you got the thing)
      objectReference: {fileID: 0}
    - target: {fileID: 4660038567173388748, guid: f7232d8a3299b4b539ed091b8ce5451a, type: 3}
      propertyPath: m_Pivot.x
