    - target: {fileID: 2740454461536182541, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: m_text
      value: '(Stay silent)

'
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "\"Don\u2019t you worry \u2019bout me, kid\""
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "\"Time\u2019s a mighty fine healer, if you let it be\""
      objectReference: {fileID: 0}
    - target: {fileID: 3875264793621075712, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: m_text
      value: How did you deal with it?
      objectReference: {fileID: 0}
    - target: {fileID: 3875264793621075712, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: m_fontSize
