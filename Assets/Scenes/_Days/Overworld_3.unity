--- !u!1001 &71475237
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 1462565334}
    m_Modifications:
    - target: {fileID: 269047118531524274, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: m_text
      value: "I\u2019m sorry for your loss"
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 3
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "\"Time, kid. Nothin\u2019 but time\""
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: '"Hurts a lot at first, but it eases up"'
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: "\"You just keep on slitherin\u2019 forward\""
      objectReference: {fileID: 0}
    - target: {fileID: 1126649762382017551, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1126649762382017551, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "\"My partner caught a nasty fungus. Ain\u2019t much a snake can do
        against it\""
      objectReference: {fileID: 0}
    - target: {fileID: 1547674041661155735, guid: 06b065a7dde2d7a488e1f662126d8480, type: 3}
      propertyPath: ThingsToActivate.Array.size
