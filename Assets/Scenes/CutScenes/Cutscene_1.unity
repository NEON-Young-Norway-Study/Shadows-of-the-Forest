    m_TransformParent: {fileID: 1765999344}
    m_Modifications:
    - target: {fileID: 269047118531524274, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_text
      value: Stay quiet
      objectReference: {fileID: 0}
    - target: {fileID: 269047118531524274, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_fontSize
      value: 14
      objectReference: {fileID: 0}
    - target: {fileID: 269047118531524274, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_fontSizeBase
      value: 14
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 5
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: '"Your father was very sad. Remember how you get joy from life?"'
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: '"When we have fresh salmon on the table, or the berry dessert that
        you love?"'
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[2]'
      value: '"That couldn''t cheer him up either"'
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[3]'
      value: '"He lost his vision in life, and he... ended it"'
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[4]'
      value: '"He is dead"'
      objectReference: {fileID: 0}
    - target: {fileID: 1547674041661155735, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: Deactivate.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1547674041661155735, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'Deactivate.Array.data[0]'
