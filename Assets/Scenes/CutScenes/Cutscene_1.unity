  m_EditorClassIdentifier: Assembly-CSharp::DialogueSystem
  dialogueText: {fileID: 6144282025440268112}
  dialogueLines:
  - Your father was very sad. Remember how to get joy from life?
  - When we have fresh salmon on the table, and the berry dessert that you love?
  - "He wasn\u2019t happy with that either"
  - He lost the vision of life, and he... ended it
  - He is dead
  textSpeed: 0.05
  playerMovement: {fileID: 0}
