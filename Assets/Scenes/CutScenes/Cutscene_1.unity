  dialogueText: {fileID: 1276313145}
  dialogueLines:
  - (It took a bit for the tears to come)
  - (I am in disbelief)
  - (Was it me?)
  - (Was I blind?)
  - (Did I not make him happy?)
  - (Was I not enough?)
  - (So many questions, no answers)
  - (My mind is spinning, my heart is crying)
  - (How will I continue from this?)
  - (All I could do was cry)
  textSpeed: 0.1
  playerMovement: {fileID: 0}
  npc: {fileID: 0}
