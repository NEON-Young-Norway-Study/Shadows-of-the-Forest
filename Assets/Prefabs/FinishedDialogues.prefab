      objectReference: {fileID: 2474412101331162962}
    - target: {fileID: 2371611682842688247, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: ThingsToActivate.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2371611682842688247, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'ThingsToActivate.Array.data[0]'
      value: 
      objectReference: {fileID: 2474412101331162962}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "Mm. Tired\u2019s normal. Heal\u2019n takes energy, ya know"
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "Don\u2019t go pushin\u2019 yerself too hard, ya ain\u2019t a machine"
      objectReference: {fileID: 0}
    - target: {fileID: 3875264793621075712, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_text
      value: "I don\u2019t wanna think today"
      objectReference: {fileID: 0}
