--- !u!1001 &1903396106
PrefabInstance:
  m_ObjectHideFlags: 0
  serializedVersion: 2
  m_Modification:
    serializedVersion: 3
    m_TransformParent: {fileID: 2071610101}
    m_Modifications:
    - target: {fileID: 269047118531524274, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_text
      value: "I\u2019m just tired"
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "Heh, I get that. Some days yer brain just says \u2018nope"
      objectReference: {fileID: 0}
    - target: {fileID: 615626891299080976, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "Just do what ya can today. That\u2019s enough, kid"
      objectReference: {fileID: 0}
    - target: {fileID: 1547674041661155735, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: ThingsToActivate.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 1547674041661155735, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'ThingsToActivate.Array.data[0]'
      value: 
      objectReference: {fileID: 1975963656}
    - target: {fileID: 2371611682842688247, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: ThingsToActivate.Array.size
      value: 1
      objectReference: {fileID: 0}
    - target: {fileID: 2371611682842688247, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'ThingsToActivate.Array.data[0]'
      value: 
      objectReference: {fileID: 1975963656}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: dialogueLines.Array.size
      value: 2
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[0]'
      value: "Mm. Tired\u2019s normal. Heal\u2019n takes energy, ya know"
      objectReference: {fileID: 0}
    - target: {fileID: 3482903838859468749, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: 'dialogueLines.Array.data[1]'
      value: "Don\u2019t go pushin\u2019 yerself too hard, ya ain\u2019t a machine"
      objectReference: {fileID: 0}
    - target: {fileID: 3875264793621075712, guid: e19442aac8583f142917d6d5607eedc2, type: 3}
      propertyPath: m_text
      value: "I don\u2019t wanna think today"
      objectReference: {fileID: 0}
